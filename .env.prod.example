# Production env for docker-compose.prod.yml. Copy to .env on the VPS:
#   cp .env.prod.example .env   # then fill in real values (never commit .env)

# --- Postgres (internal to the compose network) ---
POSTGRES_USER=pgbig
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=pgbigdata

# --- Census API key (required for ingestion) ---
# Free, instant: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
