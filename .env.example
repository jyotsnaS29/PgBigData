# Copy to .env and adjust. The CLI reads these from the environment.

# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pgbigdata

# REQUIRED. The Census API rejects keyless requests (it answers with an HTML
# "Missing Key" page). Get one free, instantly, at:
#   https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# HTTP tuning (defaults shown)
# REQUEST_TIMEOUT_S=30
# MAX_RETRIES=5
# BACKOFF_BASE_S=1.0
# MIN_REQUEST_INTERVAL_S=0.2
